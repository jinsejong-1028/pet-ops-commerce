### Health check
# 서버가 정상 실행 중인지 가장 먼저 확인합니다.
GET http://localhost:8080/api/v1/health


### Create member
# 회원 생성 API입니다.
# 응답은 success/data/message 공통 구조로 반환됩니다.
POST http://localhost:8080/api/v1/members
Content-Type: application/json

{
  "email": "user2@example.com",
  "password": "password123",
  "name": "홍길동"
}

### Create member
# 회원 생성 API입니다.
# 응답은 success/data/message 공통 구조로 반환됩니다.
POST http://localhost:8080/api/v1/members
Content-Type: application/json

{
  "email": "admin@example.com",
  "password": "password123",
  "name": "관리자"
}


### Get member
# 위 회원 생성 응답의 data.id 값을 사용해 회원 단건 조회를 확인합니다.
GET http://localhost:8080/api/v1/members/4


### Duplicate email
# 같은 이메일로 다시 생성하면 409 Conflict와 공통 실패 응답이 나와야 정상입니다.
POST http://localhost:8080/api/v1/members
Content-Type: application/json

{
  "email": "user2@example.com",
  "password": "password123",
  "name": "홍길동"
}


### Validation error
# 잘못된 이메일과 짧은 비밀번호를 보내 400 공통 실패 응답을 확인합니다.
POST http://localhost:8080/api/v1/members
Content-Type: application/json

{
  "email": "invalid-email",
  "password": "123",
  "name": ""
}